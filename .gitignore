# =====================================================================
#  AIS  --  .gitignore
#  Keep: source, docs, and the legacy/ preservation snapshot.
#  Never commit: build artifacts, binaries, or personal index files.
# =====================================================================

# ---- C engine (c/): build artifacts & binaries ----
# (.exe variants are the native MinGW Windows builds of the same binaries)
*.o
*.d
/c/ais
/c/ais.exe
/c/ais_ut
/c/ais_ut.exe
/c/libais.a
/c/libais.so

# ---- runtime / data: personal indexes are not part of the code repo ----
# (the plain-text store belongs in a separate data repo; force-add a seed
#  with `git add -f` if you ever want one here)
*.db
/data/

# ...but DO track the committed seed/sample index (test fixture + usage example)

# ---- Java web service (java/): build output only ----
# Scoped to java/ so the preserved legacy/ jars and the future java/lib
# dependencies are NOT ignored.
/java/build/
/java/dist/
/java/bin/
/java/**/*.class
/java/**/*.war

# ---- editor / OS noise ----
*~
*.swp
.DS_Store
tests/INDEX/idx/
tests/INDEX/next_id
tests/INDEX/tomb
tests/INDEX/lock
/ais
/ais.exe
/releases/
/dist/

# ---- example/ sample index: a small, ready-to-use sample. Track store (the
#  human-readable source of truth), version, and the idx/ postings so recall
#  works straight from a clone; ignore the churny runtime files (rebuilt on any
#  write, and recoverable from store via `ais --compact`) ----
/example/next_id
/example/off
/example/lock
/example/blobs/

# WASM PWA build output (emcc); built in CI, not committed
/app/engine/
